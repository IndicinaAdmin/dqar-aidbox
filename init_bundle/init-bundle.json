      "resource": {
        "resourceType": "ViewDefinition",
        "name": "condition_summary",
        "resource": "Condition",
        "status": "active",
        "description": "Condition summary for denominator identification across measures.",
        "select": [
          {
            "column": [
              {
                "name": "condition_id",
                "path": "getResourceKey()"
              },
              {
                "name": "patient_id",
                "path": "subject.getId()"
              },
              {
                "name": "encounter_id",
                "path": "encounter.getId()"
              },
              {
                "name": "clinical_status",
                "path": "clinicalStatus.coding.code.first()"
              },
              {
                "name": "verification_status",
                "path": "verificationStatus.coding.code.first()"
              },
              {
                "name": "onset_date",
                "path": "onset.ofType(dateTime)"
              },
              {
                "name": "recorded_date",
                "path": "recordedDate"
              }
            ]
          },
          {
            "forEach": "code.coding",
            "column": [
              {
                "name": "code_system",
                "path": "system"
              },
              {
                "name": "code_value",
                "path": "code"
              },
              {
                "name": "code_display",
                "path": "display"
              }
            ]
          }
        ]
      },
      "request": {
        "method": "PUT",
        "url": "ViewDefinition/condition_summary"
      }
    },
